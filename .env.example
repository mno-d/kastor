HOST=127.0.0.1
PORT=7676

# Generate this with `kastor init` or set a long random value for non-interactive
# deployments. Never commit a real owner token.
# KASTOR_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret

# Comma-separated local project roots Kastor may open. Keep this narrow.
# Windows example: KASTOR_ALLOWED_ROOTS=C:\Users\you\Projects
# macOS/Linux example: KASTOR_ALLOWED_ROOTS=/Users/you/projects
KASTOR_ALLOWED_ROOTS=/absolute/path/to/your/projects

# Public HTTPS origin for MCP clients. Do not include /mcp.
# KASTOR_PUBLIC_BASE_URL=https://your-tunnel-host.example.com

# Host allowlist. Avoid `*` unless you are debugging on a trusted network.
# KASTOR_ALLOWED_HOSTS=localhost,127.0.0.1,your-tunnel-host.example.com

# Optional OAuth tuning.
# KASTOR_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# KASTOR_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# KASTOR_OAUTH_SCOPES=kastor
# KASTOR_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1

# minimal keeps the first-run tool surface smaller. Use "full" only after you
# understand the local access you are granting to your MCP host.
KASTOR_TOOL_MODE=minimal
KASTOR_TOOL_NAMING=short

# off | changes | full
KASTOR_WIDGETS=changes

# desktop | chrome | none
# desktop opens the Windows ChatGPT app; chrome opens https://chatgpt.com in a
# dedicated Chrome profile. Use chrome when the Windows ChatGPT app is broken.
KASTOR_CHATGPT_CLIENT=desktop
# KASTOR_CHATGPT_CHROME_PROFILE=%LOCALAPPDATA%\KastorChatGPTChrome

KASTOR_LOG_LEVEL=info
KASTOR_LOG_FORMAT=json
KASTOR_LOG_REQUESTS=1
KASTOR_LOG_ASSETS=0
KASTOR_LOG_TOOL_CALLS=1
KASTOR_LOG_SHELL_COMMANDS=0

# KASTOR_TRUST_PROXY=1
# KASTOR_STATE_DIR=~/.local/share/kastor
# KASTOR_WORKTREE_ROOT=~/.kastor/worktrees
# KASTOR_AGENT_DIR=~/.codex
# KASTOR_SKILLS=0
# KASTOR_SKILL_PATHS=~/.codex/skills,~/.claude/skills
